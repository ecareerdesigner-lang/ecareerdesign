ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: job search feature. Any of these can be left blank and the app
# will just skip that source with a warning shown in the UI.
USAJOBS_API_KEY=your-usajobs-key-here
USAJOBS_EMAIL=your-email@example.com
ADZUNA_APP_ID=your-adzuna-app-id-here
ADZUNA_APP_KEY=your-adzuna-app-key-here
JOOBLE_API_KEY=your-jooble-key-here

# Optional: email capture ("Email me a copy" + mailing list opt-in).
# Without these, that feature shows an error but nothing else breaks.
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL="eCareer Design <hello@ecareerdesign.net>"
RESEND_AUDIENCE_ID=your-resend-audience-id-here
